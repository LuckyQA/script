    Multi = true,
    Default = {},
})

MultiDropdown:OnChanged(function(Value)
    if isUpdating then return end
    
    local latestAdded = nil
    local currentSelection = {}

    for item, state in pairs(Value) do
        if state then
            currentSelection[item] = true
            if not SelectedItems[item] then
                latestAdded = item
            end
        end
    end

    if latestAdded and ItemConfigs[latestAdded] then
        local conflicts = ItemConfigs[latestAdded].conflicts
        local needsUpdate = false
        
        for _, conflictName in ipairs(conflicts) do
            if currentSelection[conflictName] then
                currentSelection[conflictName] = nil
                needsUpdate = true
            end
        end

        if needsUpdate then
            isUpdating = true
            MultiDropdown:SetValue(currentSelection)
            isUpdating = false
        end
    end

    SelectedItems = currentSelection
end)

