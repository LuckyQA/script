local function getMonsterRoots()
    local roots = {}
    if workspace:FindFirstChild("Mobs") then
        table.insert(roots, workspace.Mobs)
    end
    return roots
end

local function getHRP()
    local char = player.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function equipTool()
    if Settings.Tool and player.Character then
        if not player.Character:FindFirstChild(Settings.Tool) then
            local tool = player.Backpack:FindFirstChild(Settings.Tool)
            if tool then
                tool.Parent = player.Character
            end
        end
    end
end

local function getFarmCFrame(mobHRP)
    local d = Settings.Distance
    if Settings.Position == "Behind" then
        return mobHRP.CFrame * CFrame.new(0, 0, d)
    elseif Settings.Position == "Above" then
        return mobHRP.CFrame * CFrame.new(0, d, 0)
    elseif Settings.Position == "Below" then
        return mobHRP.CFrame * CFrame.new(0, -d, 0)
    end
    return mobHRP.CFrame
end


local function updateMobCache()
    table.clear(MobCache)

    for _, island in ipairs(mobsFolder:GetChildren()) do
        local children = island:GetChildren()
        for i = 1, #children do
            local mob = children[i]
            if mob:FindFirstChild("HumanoidRootPart") then
                MobCache[#MobCache+1] = mob
            end
        end
    end
end

task.spawn(function()
    while true do
        updateMobCache()
        task.wait()
    end
end)

local function findTarget()
    local myHRP = getHRP()
    if not myHRP then return end

    local closest, dist = nil, 1e9

    for i = 1, #MobCache do
        local mob = MobCache[i]
        if Settings.Monsters[mob.Name] then
            local hrp = mob:FindFirstChild("HumanoidRootPart")
            local hum = mob:FindFirstChildOfClass("Humanoid")

            if hrp and hum and hum.Health > 0 then
                local d = (myHRP.Position - hrp.Position).Magnitude
                if d < dist then
                    dist = d
                    closest = mob
                end
            end
        end
    end

    CurrentTarget = closest
    return closest, closest and closest:FindFirstChild("HumanoidRootPart")
end

local function bringMonsters(targetHRP)
    if not Settings.BringMob or not targetHRP then return end

    local name = targetHRP.Parent.Name

    for i = 1, #MobCache do
        local mob = MobCache[i]
        if mob.Name == name and mob ~= targetHRP.Parent then
            local hrp = mob:FindFirstChild("HumanoidRootPart")
            local hum = mob:FindFirstChildOfClass("Humanoid")

            if hrp and hum and hum.Health > 0 then
                hrp.CFrame = targetHRP.CFrame
                hrp.CanCollide = false
            end
        end
    end
end

