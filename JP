local function AutoStoreLoop()
    if not Settings.AutoStore then
        if storeconn then
            storeconn:Disconnect()
            storeconn = nil
        end
        return
    end

    for _, tool in ipairs(player.Backpack:GetChildren()) do
        StoreTool(tool)
    end

    if storeconn then storeconn:Disconnect() end

    storeconn = player.Backpack.ChildAdded:Connect(function(tool)
        if not Settings.AutoStore then return end
        StoreTool(tool)
    end)
end

local function AutoCraftLoop()
    if craftconn then craftconn:Disconnect() end

    craftconn = RunService.Heartbeat:Connect(function()
        if not Settings.AutoCraft then
            craftconn:Disconnect()
            craftconn = nil
            return
        end

        local now = os.clock()
        if now - lastCraftFire >= craftcooldown then
            lastCraftFire = now
            pcall(function()
                ReplicatedStorage.System.CraftItem:FireServer(Settings.SelectedCraftItem)
            end)
        end
    end)
end

