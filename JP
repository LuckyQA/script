local Lighting = game:GetService("Lighting")
local Terrain = workspace:WaitForChild("Terrain")

local function ApplyPotato()
    local function optimize(obj)
        if obj:IsA("BasePart") then
            obj.Material = Enum.Material.SmoothPlastic
            obj.Reflectance = 0

        elseif obj:IsA("MeshPart") then
            obj.RenderFidelity = Enum.RenderFidelity.Performance
            obj.Material = Enum.Material.SmoothPlastic
            obj.CollisionFidelity = Enum.CollisionFidelity.Box

        elseif obj:IsA("Decal") or obj:IsA("Texture") then

        elseif obj:IsA("ParticleEmitter") then
            if obj.Rate > 10 then
                obj.Rate = obj.Rate * 0.1 
            end
        elseif obj:IsA("Trail") or obj:IsA("Fire") or obj:IsA("Smoke") then
            obj.Enabled = true 
        end
    end

    Lighting.GlobalShadows = false
    
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect") then
            v.Enabled = false
        elseif v:IsA("BloomEffect") then
            v.Intensity = 0.1
        end
    end

    for _, v in pairs(workspace:GetDescendants()) do 
        optimize(v) 
    end

    workspace.DescendantAdded:Connect(function(v)
        task.wait()
        optimize(v)
    end)

    Terrain.WaterWaveSize = 0
    Terrain.WaterWaveSpeed = 0
    Terrain.WaterReflectance = 0
    Terrain.WaterTransparency = 1
end

