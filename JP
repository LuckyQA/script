end

local lastSkill = 0

local function AutoFarmLoop()
    if _G.FarmLoop then return end
    _G.FarmLoop = true

    while Settings.Enabled do
        task.wait()

        local myHRP = getHRP()
        if not myHRP then continue end

        local mob, hrp = findTarget()
        if not mob or not hrp then continue end

        equipTool()

        if Settings.BringMob then
            bringMonsters(hrp)
        end

        local cf = getFarmCFrame(hrp)
        myHRP.CFrame = CFrame.lookAt(cf.Position, hrp.Position)
        myHRP.Velocity = Vector3.zero

        for key, v in pairs(Settings.Skills) do
            if v then
                PressKey(key)
            end
        end

        local now = os.clock()
        if now - lastSkill > 0.2 then
            lastSkill = now
            ReplicatedStorage.BridgeNet2.dataRemoteEvent:FireServer({
                [1] = {[1] = "Skill",[2] = "A"},
                [2] = "\4"
            })
        end
    end

    _G.FarmLoop = nil
end

