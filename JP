local function AutoLevelLoop()
    while Settings.AutoLevel do
        task.wait(0.5)
        pcall(function()
            local levelValue = player:WaitForChild("Data"):WaitForChild("Level").Value
            local currentTargetConfig = nil

            for _, config in ipairs(LevelConfigs) do
                if levelValue >= config.Min and levelValue < config.Max then
                    currentTargetConfig = config
                    break
                end
            end

            if currentTargetConfig then
                Settings.Monsters = {[currentTargetConfig.Monster] = true}
                
                local myHRP = getHRP()
                local islandPos = IslandLocations[currentTargetConfig.Island]
                
                if myHRP and islandPos then
                    myHRP.CFrame = islandPos
                end

                if not Settings.Enabled then
                    Settings.Enabled = true
                    task.spawn(AutoFarmLoop)
                end
            end
        end)
    end
    Settings.Enabled = false
end

