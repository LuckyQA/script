local skillLoopRunning = false

local function AutoFarmSkillLoop()
    if skillLoopRunning then return end
    skillLoopRunning = true

    while Settings.Enabled do
        task.wait(0.3)
        if CurrentTarget and player.Character then
            for key, isEnabled in pairs(Settings.Skills) do
                if isEnabled and Settings.Enabled then
                    PressKey(key)
                end
            end
        end
    end

    skillLoopRunning = false
end

local function AutoFarmLoop()
    task.spawn(AutoFarmSkillLoop)

    while Settings.Enabled do
        RunService.Heartbeat:Wait()

        pcall(function()
            local myHRP = getHRP()
            local mobModel, mobHRP = findTarget()

            if mobModel and mobHRP then
                equipTool()
                if not pressedFOnce and Settings.Tool == "Kirito" then
                    local char = player.Character
                    if char and char:FindFirstChild("Kirito") then
                        PressKey("F")
                        pressedFOnce = true
                    end
                end

                if Settings.BringMob then
                    bringMonsters(mobHRP)
                end

                local targetCFrame = getFarmCFrame(mobHRP)
                myHRP.CFrame = CFrame.lookAt(targetCFrame.Position, mobHRP.Position)
                myHRP.Velocity = Vector3.new(0,0,0)

                game:GetService("ReplicatedStorage").BridgeNet2.dataRemoteEvent:FireServer({[1] = {[1] = "Skill",[2] = "A",},[2] = "",})
            end
        end)
    end
end

