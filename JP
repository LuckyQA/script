            task.wait(0.3)
            if autoSkipBtn then clickGuiButton(autoSkipBtn) end
            PressKey("J")
            
            if not Settings.Enabled then
                Settings.Monsters = {
                    ["Demon"] = true, 
                    ["Demon Boss"] = true, 
                } 
                Settings.Enabled = true
                task.spawn(AutoFarmLoop)
            end

            while Settings.AutoRaidInf and task.wait(1) do
                local finishGui = raidGui:FindFirstChild("End") 
                local isFinished = finishGui and finishGui.Visible

                if waveLabel and not isFinished then
                    local currentWave = tonumber(string.match(waveLabel.Text, "%d+"))
                    
                    if currentWave and currentWave >= 1000 then
                        for i = 1, 3 do
                            if finishGui and finishGui.Visible then break end

                            local character = player.Character
                            if character then
                                character:BreakJoints()
                            end
                            player.CharacterAdded:Wait()
                            task.wait(0.5) 
                        end
                        task.wait(5) 
                    end
                end

                if isFinished then
                    if ReplayBtn then 
                        clickGuiButton(ReplayBtn) 
                        PressKey("J")
                        task.wait(2)
                    end
                end

                if Settings.Enabled and not isFinished then
                    for key, isEnabled in pairs(Settings.Skills) do
                        if isEnabled then
                            PressKey(key)
                        end
                    end
                end

                for _, item in ipairs(player.Backpack:GetChildren()) do
                    if item:IsA("Tool") and item.Name ~= Settings.Tool then
                        pcall(function()
                            ReplicatedStorage.System.Inv.Inventory:InvokeServer("Add", item.Name)
                        end)
                    end
                end
            end
        end)
    end
end

