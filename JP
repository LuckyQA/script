local function AutoRaidRush()
    local MainMapID = 110029522258215
    local RaidRushMapID = 123886389200671
    local TargetPos = Vector3.new(11.02020263671875, 85, -294.40069580078125)

    if game.PlaceId == MainMapID then
        pcall(function()
            local hrp = getHRP()
            if hrp then
                BossRushClickAction()
                task.wait(1)
                local rushPart = workspace:FindFirstChild("BossRushPart")
                if rushPart then hrp.CFrame = rushPart:GetPivot() end
                
                ReplicatedStorage.System.Inv.Inventory:InvokeServer("Add", "Rush Ticket")
                ReplicatedStorage.System.Inv.Inventory:InvokeServer("Add", "Rush Ticket")
            end
        end)

    elseif game.PlaceId == RaidRushMapID then
        local hasSkill = false
        for _, isEnabled in pairs(Settings.Skills) do
            if isEnabled then
                hasSkill = true
                break
            end
        end

        if not hasSkill then
            Fluent:Notify({
                Title = "Warning",
                Content = "Please select at least one skill first!",
                Duration = 5
            })
            return
        end

        task.spawn(function()
            local player = game.Players.LocalPlayer
            local playerGui = player:WaitForChild("PlayerGui")
            local raidGui = playerGui:WaitForChild("Raid")
            local startBtn = raidGui:WaitForChild("Start", 5)
            local autoSkipBtn = raidGui:WaitForChild("AutoSkip", 5)
            local ReplayBtn = raidGui:WaitForChild("Replay", 5)

            if startBtn then
                clickGuiButton(startBtn)
                task.wait(0.2)
                clickGuiButton(startBtn)
            end

            task.wait(1)
            if autoSkipBtn then clickGuiButton(autoSkipBtn) end
            
            PressKey("J")

            while Settings.AutoRaidRush do
                pcall(function()
                    local character = player.Character
                    if not character then return end
                    local hrp = character:FindFirstChild("HumanoidRootPart")
                    local hum = character:FindFirstChildOfClass("Humanoid")
                    
                    if Settings.Tool then
                        local tool = player.Backpack:FindFirstChild(Settings.Tool)
                        if tool then hum:EquipTool(tool) end
                    end

                    if hrp and hum then
                        hum.PlatformStand = true
                        hrp.CFrame = CFrame.new(TargetPos) * CFrame.Angles(math.rad(-90), 0, 0)
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        hrp.RotVelocity = Vector3.new(0, 0, 0)
                        
                        for key, isEnabled in pairs(Settings.Skills) do
                            if isEnabled then PressKey(key) end
                        end
                    end
                end)
                
                local endGui = raidGui:FindFirstChild("End")
                if endGui and endGui.Visible then 
                    task.wait(1)
                    if ReplayBtn then clickGuiButton(ReplayBtn) end
                end
                task.wait()
            end
        end)
    end
end

